{
  "name": "srm-bfhl-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @srijan/frontend\" \"npm run dev --workspace @srijan/backend\"",
    "build": "npm run build --workspace @srijan/frontend && npm run build --workspace @srijan/backend",
    "start": "concurrently \"npm run start --workspace @srijan/frontend\" \"npm run start --workspace @srijan/backend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
